<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.MainPage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="School App" FontSize="32" HorizontalOptions="Center" />
            <Label Text="Powered by .NET 10 MAUI" HorizontalOptions="Center" />
            <Label x:Name="StatusLabel" Text="Tap the button to count" HorizontalOptions="Center" />
           
            <Button Text="Check" Clicked="OnTapClicked" HorizontalOptions="Center" Margin="0,10" />
            <Button Text="Open student lists" Clicked="OnOpenStudentsClicked" HorizontalOptions="Center" />

            <BoxView Color="Gray" HeightRequest="1" Margin="0,30,0,20" />

            <Label Text="Name card" FontSize="24" FontAttributes="Bold" HorizontalOptions="Start" Margin="0,0,0,10" />

            <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Edit your name" Margin="0,0,0,15" />
            <Label Text="{Binding Name}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Start" Margin="0,0,0,5" />

            <Label Text="{Binding City}" FontSize="16" TextColor="Gray" HorizontalOptions="Start" />
            <Button Text="Shout the name" Clicked="OnShoutClicked" HorizontalOptions="Fill" Margin="0,10,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>